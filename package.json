{
  "name": "spartan-ng-mcp",
  "version": "1.0.1",
  "description": "MCP server exposing Spartan Angular UI documentation and component tools.",
  "main": "server.js",
  "type": "module",
  "bin": {
    "spartan-ng-mcp": "server.js"
  },
  "files": [
    "server.js",
    "tools/"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "echo \"No tests configured\" && exit 0",
    "prepublish": "echo 'Ready to publish spartan-ng-mcp'",
    "prepare": "husky || true"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "spartan",
    "angular",
    "ui",
    "spartan-ng",
    "components",
    "documentation"
  ],
  "author": "Carlos Palacin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlospalacin/spartan-ng-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/carlospalacin/spartan-ng-mcp/issues"
  },
  "homepage": "https://github.com/carlospalacin/spartan-ng-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.7.1",
    "husky": "9.1.7"
  }
}
