{
  "name": "spartan-ng-mcp",
  "version": "2.0.4",
  "description": "MCP server for the Spartan Angular UI ecosystem — component discovery, source code, installation commands, and project context",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spartan-ng-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "src/registry/registry.json",
    "README.md",
    "ReadMe.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "generate-registry": "tsx scripts/generate-registry.ts",
    "mcp-client": "tsx scripts/mcp-client.ts",
    "mcp-test": "tsx scripts/mcp-test-battery.ts",
    "prerelease": "npm run generate-registry && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky || true"
  },
  "keywords": [
    "spartan",
    "angular",
    "mcp",
    "model-context-protocol",
    "ui-components",
    "brain",
    "helm"
  ],
  "author": "José Carlos Rodríguez Palacín",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlospalacin/spartan-ng-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/carlospalacin/spartan-ng-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "cosmiconfig": "^9.0.0",
    "dedent": "^1.5.0",
    "dotenv": "^17.4.1",
    "fuzzysort": "^3.1.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
